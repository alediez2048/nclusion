# Nclusion Environment Variables
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost:5432/nclusion

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
HTGN_MINT=EXVsw8cxwVZCbiaSp52RbqKAgnhARxWvCTiv6D4c9YpY
RELAY_KEYPAIR=<base58-encoded-keypair>

# Odds Provider (select one)
ODDS_API_KEY=<your-api-key>
ODDS_PROVIDER=the-odds-api

# Auth
JWT_SECRET=<random-secret-for-development>
